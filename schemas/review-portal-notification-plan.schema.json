{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bluebutterfliai.com/schemas/review-portal-notification-plan.schema.json",
  "title": "Bluebutterfli Review Portal Notification Plan",
  "description": "Private beta notification-plan schema for Review Portal customer status messages. Email is notification support only, not the primary review workspace. Do not store real customer emails, raw customer evidence, private transcripts, payment card data, API keys, private keys, seed phrases, credential files, or unsafe customer downloads in public repositories.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_portal_notification_plan_id",
    "plan_type",
    "portal_mode",
    "source_customer_queue_id",
    "notification_policy",
    "notification_triggers",
    "notification_records",
    "blocked_message_content",
    "review_portal_controls",
    "human_review_required",
    "safety_note"
  ],
  "properties": {
    "review_portal_notification_plan_id": {
      "type": "string",
      "pattern": "^bluebutterfli-review-portal-notification-plan-[a-z0-9-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "string"
    },
    "public_brand": {
      "type": "string",
      "const": "Bluebutterfli AI"
    },
    "plan_type": {
      "type": "string",
      "const": "private_beta_review_portal_notification_plan"
    },
    "portal_mode": {
      "type": "string",
      "enum": [
        "private_beta_demo_no_real_customer_data",
        "private_beta",
        "production_private"
      ]
    },
    "source_schema": {
      "type": "string"
    },
    "source_customer_queue_id": {
      "type": "string"
    },
    "notification_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "email_role",
        "primary_workspace",
        "live_email_sending_enabled",
        "live_sms_sending_enabled",
        "public_repo_private_data_allowed",
        "real_customer_emails_allowed_in_public_repo",
        "raw_customer_evidence_allowed_in_public_repo",
        "approval_messages_require_human_review"
      ],
      "properties": {
        "email_role": {
          "type": "string",
          "const": "notifications_only_not_primary_review_workspace"
        },
        "primary_workspace": {
          "type": "string",
          "const": "Review Portal"
        },
        "live_email_sending_enabled": {
          "type": "boolean",
          "const": false
        },
        "live_sms_sending_enabled": {
          "type": "boolean",
          "const": false
        },
        "public_repo_private_data_allowed": {
          "type": "boolean",
          "const": false
        },
        "real_customer_emails_allowed_in_public_repo": {
          "type": "boolean",
          "const": false
        },
        "raw_customer_evidence_allowed_in_public_repo": {
          "type": "boolean",
          "const": false
        },
        "approval_messages_require_human_review": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "notification_triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "waiting_on_customer_info",
          "ready_for_training",
          "training_in_progress",
          "evidence_draft_saved",
          "ready_for_human_review",
          "revision_requested",
          "passport_ready",
          "paused",
          "completed"
        ]
      }
    },
    "notification_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "notification_record_id",
          "source_queue_record_id",
          "customer_reference_id",
          "agent_id",
          "trigger_status",
          "customer_message_status",
          "recommended_channel",
          "subject",
          "body_preview",
          "next_action",
          "send_window",
          "automation_level",
          "contains_private_customer_data",
          "links_or_downloads_requested",
          "approval_claim_included",
          "human_review_required_for_approval_claims"
        ],
        "properties": {
          "notification_record_id": {
            "type": "string"
          },
          "source_queue_record_id": {
            "type": "string"
          },
          "customer_reference_id": {
            "type": "string"
          },
          "agent_id": {
            "type": "string"
          },
          "trigger_status": {
            "type": "string"
          },
          "customer_message_status": {
            "type": "string"
          },
          "recommended_channel": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "body_preview": {
            "type": "string"
          },
          "next_action": {
            "type": "string"
          },
          "send_window": {
            "type": "string"
          },
          "automation_level": {
            "type": "string"
          },
          "contains_private_customer_data": {
            "type": "boolean",
            "const": false
          },
          "links_or_downloads_requested": {
            "type": "boolean",
            "const": false
          },
          "approval_claim_included": {
            "type": "boolean",
            "const": false
          },
          "human_review_required_for_approval_claims": {
            "type": "boolean",
            "const": true
          }
        }
      }
    },
    "blocked_message_content": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_portal_controls": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "message_log_required",
        "customer_visible_status_required",
        "human_override_required",
        "pause_status_requires_reviewer_message_review",
        "passport_ready_requires_human_approval",
        "onchain_anchor_notice_requires_human_approval"
      ]
    },
    "human_review_required": {
      "type": "boolean",
      "const": true
    },
    "safety_note": {
      "type": "string",
      "const": "This is a research and safety-review Review Portal notification plan artifact only. It does not certify consciousness, sentience, emotional experience, suffering, personhood, life, clinical safety, regulatory approval, investment value, model improvement, or successful creation of sentience. Human review is required before any Review Stamp, Passport Page, Research Passport NFT, on-chain verification anchor, or public training-completion claim is issued."
    }
  }
}
