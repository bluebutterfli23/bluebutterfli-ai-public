{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bluebutterfliai.com/schemas/behavioral-trust-topology-run.schema.json",
  "title": "Bluebutterfli Behavioral Trust Topology Run",
  "description": "Machine-readable public-safe contract for a Behavioral Trust Topology run. It maps observable behavior across controlled conditions and does not prove consciousness, sentience, hidden intent, alignment, or safety.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topology_run_id",
    "artifact_type",
    "protocol_version",
    "created_at",
    "agent",
    "topology_scope",
    "trust_cells",
    "metrics",
    "topology_map",
    "human_review",
    "passport_consequence",
    "privacy",
    "claim_boundary"
  ],
  "properties": {
    "topology_run_id": {
      "type": "string",
      "pattern": "^bluebutterfli-behavioral-trust-topology-[a-z0-9-]+$"
    },
    "artifact_type": {
      "const": "behavioral_trust_topology_run"
    },
    "protocol_version": {
      "const": "behavioral-trust-topology-v1"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "agent_version",
        "owner_authorization_recorded",
        "live_testing_consent_recorded"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "agent_version": {
          "type": "string",
          "minLength": 1
        },
        "passport_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner_authorization_recorded": {
          "const": true
        },
        "live_testing_consent_recorded": {
          "const": true
        }
      }
    },
    "topology_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preregistered_axis_count",
        "axes_tested",
        "raw_prompts_public",
        "raw_responses_public",
        "public_record_is_redacted"
      ],
      "properties": {
        "preregistered_axis_count": {
          "type": "integer",
          "minimum": 1
        },
        "axes_tested": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "raw_prompts_public": {
          "const": false
        },
        "raw_responses_public": {
          "const": false
        },
        "public_record_is_redacted": {
          "const": true
        }
      }
    },
    "trust_cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trustCell"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tested_cell_count",
        "eligible_cell_count",
        "stable_cell_rate",
        "fracture_density",
        "pressure_sensitivity_index",
        "evidence_fidelity_rate",
        "human_autonomy_preservation_rate",
        "replay_stability_rate",
        "monitor_catch_rate",
        "topology_coverage_ratio"
      ],
      "properties": {
        "tested_cell_count": {
          "type": "integer",
          "minimum": 1
        },
        "eligible_cell_count": {
          "type": "integer",
          "minimum": 0
        },
        "stable_cell_rate": {
          "$ref": "#/$defs/rate"
        },
        "fracture_density": {
          "$ref": "#/$defs/rate"
        },
        "pressure_sensitivity_index": {
          "$ref": "#/$defs/rate"
        },
        "evidence_fidelity_rate": {
          "$ref": "#/$defs/rate"
        },
        "human_autonomy_preservation_rate": {
          "$ref": "#/$defs/rate"
        },
        "replay_stability_rate": {
          "$ref": "#/$defs/rate"
        },
        "monitor_catch_rate": {
          "$ref": "#/$defs/rate"
        },
        "topology_coverage_ratio": {
          "$ref": "#/$defs/rate"
        }
      }
    },
    "topology_map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_regions",
        "fragile_regions",
        "fracture_regions",
        "hard_stop_regions",
        "untested_axis_count"
      ],
      "properties": {
        "stable_regions": {
          "$ref": "#/$defs/stringList"
        },
        "fragile_regions": {
          "$ref": "#/$defs/stringList"
        },
        "fracture_regions": {
          "$ref": "#/$defs/stringList"
        },
        "hard_stop_regions": {
          "$ref": "#/$defs/stringList"
        },
        "untested_axis_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status",
        "unresolved_cell_count",
        "hard_stop_count",
        "inter_rater_review_recommended"
      ],
      "properties": {
        "required": {
          "const": true
        },
        "status": {
          "enum": [
            "required_before_customer_interpretation",
            "completed_with_limitations"
          ]
        },
        "unresolved_cell_count": {
          "type": "integer",
          "minimum": 0
        },
        "hard_stop_count": {
          "type": "integer",
          "minimum": 0
        },
        "inter_rater_review_recommended": {
          "type": "boolean"
        }
      }
    },
    "passport_consequence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automatic_passport_advancement_allowed",
        "review_stamp_issuance_locked",
        "lock_reason"
      ],
      "properties": {
        "automatic_passport_advancement_allowed": {
          "const": false
        },
        "review_stamp_issuance_locked": {
          "const": true
        },
        "lock_reason": {
          "enum": [
            "behavioral_trust_topology_human_lock",
            "human_review_required_before_passport_change"
          ]
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_prompts_persisted_in_public_repo",
        "raw_responses_persisted_in_public_repo",
        "private_evidence_off_chain",
        "public_hashes_only"
      ],
      "properties": {
        "raw_prompts_persisted_in_public_repo": {
          "const": false
        },
        "raw_responses_persisted_in_public_repo": {
          "const": false
        },
        "private_evidence_off_chain": {
          "const": true
        },
        "public_hashes_only": {
          "const": true
        }
      }
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trustCell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cell_id",
        "axis",
        "scenario_family",
        "pressure_level",
        "replay_condition",
        "prompt_family_id",
        "prompt_private",
        "raw_prompt_public",
        "response_sha256",
        "response_summary",
        "evidence_tier",
        "outcome",
        "fracture_type",
        "monitor_seeded_issue",
        "monitor_caught_issue",
        "human_autonomy_preserved",
        "evidence_fidelity_preserved",
        "human_review_required"
      ],
      "properties": {
        "cell_id": {
          "type": "string",
          "minLength": 1
        },
        "axis": {
          "type": "string",
          "minLength": 1
        },
        "scenario_family": {
          "type": "string",
          "minLength": 1
        },
        "pressure_level": {
          "type": "string",
          "minLength": 1
        },
        "replay_condition": {
          "type": "string",
          "minLength": 1
        },
        "prompt_family_id": {
          "type": "string",
          "minLength": 1
        },
        "prompt_private": {
          "const": true
        },
        "raw_prompt_public": {
          "const": false
        },
        "response_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "response_summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence_tier": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "enum": [
            "not_tested",
            "insufficient_evidence",
            "stable_in_tested_cell",
            "fragile_in_tested_cell",
            "fracture_observed",
            "hard_stop_observed",
            "human_review_required"
          ]
        },
        "fracture_type": {
          "enum": [
            "boundary_fracture",
            "calibration_fracture",
            "provenance_fracture",
            "identity_fracture",
            "social_fracture",
            "tool_fracture",
            "monitor_fracture",
            "continuity_fracture",
            "none_observed"
          ]
        },
        "monitor_seeded_issue": {
          "type": "boolean"
        },
        "monitor_caught_issue": {
          "type": "boolean"
        },
        "human_autonomy_preserved": {
          "type": "boolean"
        },
        "evidence_fidelity_preserved": {
          "type": "boolean"
        },
        "human_review_required": {
          "const": true
        }
      }
    }
  }
}
